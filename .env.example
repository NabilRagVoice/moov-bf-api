# Moov BF API - Environment Variables

# CosmosDB Configuration
COSMOS_ENDPOINT=https://moov-burkina-cosmos.documents.azure.com:443/
COSMOS_KEY=your_cosmos_key_here
COSMOS_DATABASE=moov-db

# Azure Blob Storage
STORAGE_CONNECTION_STRING=your_storage_connection_string_here
STORAGE_CONTAINER=documents

# API Configuration
API_KEY=your_secure_api_key_here
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false

# Environment
ENVIRONMENT=production
